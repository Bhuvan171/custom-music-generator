# Python
__pycache__/
*.pyc

# Virtual env
venv/

# Large / regenerable data (raw audio, cached latents, external dataset clone)
data/stems/
data/latents/
data/jamendo_audio_low/
data/test_stems/
mtg-jamendo-dataset/
# Extracted conditioning features (~1.3 GB, regenerable via extract_features.py).
# The *_stats.json files are NOT ignored — they are small, and training cannot run without
# them (JamendoDataset raises if feature_stats.json is missing).
data/features/
data/features_val/

# Audio captions (~238 MB, regenerable via caption_audio.py -- expensive to regenerate, real
# vLLM compute time, but still raw derived data, not source) and their frozen-T5 embeddings
# (~5.9 GB, cheap/fast to regenerate from captions via compute_text_embeddings.py).
data/captions/
data/captions_val/
data/text_emb/
data/text_emb_val/

# Model checkpoints (large binaries)
checkpoints/

# Generated run artifacts
samples/
results/
*.log
*.csv

# Your own reference tracks — audio stays local. The README is kept.
references/*
!references/README.md
data/tag_embeddings.npz

# Misc scratch
gpu_check.txt

# Claude Code local settings (machine-specific)
.claude/settings.local.json
